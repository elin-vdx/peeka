# Copy to .env.local and fill in the values.

# Generate with: openssl rand -base64 32
AUTH_SECRET=

# From Google Cloud Console > APIs & Services > Credentials > OAuth client ID.
# Authorized redirect URI must be:
#   http://localhost:3000/api/auth/callback/google   (dev)
#   https://your-domain.com/api/auth/callback/google  (prod)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Cloudflare R2 (S3-compatible API). Create an R2 bucket + API token.
# Endpoint is https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=peeka

# Shared secret the CI ingest endpoint checks. Generate with: openssl rand -hex 32
PEEKA_INGEST_TOKEN=

# GitHub token (PAT or App token) with the repo:status scope, used to post commit statuses.
GITHUB_TOKEN=

# Public base URL of this app; used to build commit-status target links AND
# the QStash callback URL for the diff worker. Must be publicly reachable for
# QStash to deliver jobs (use a tunnel like cloudflared/ngrok in dev).
APP_URL=http://localhost:3000

# Upstash QStash — async diff queue. From console.upstash.com/qstash.
# If QSTASH_TOKEN is unset, ingest diffs inline (fine for local dev / small loads).
QSTASH_TOKEN=
# Signing keys used by /api/diff-worker to verify incoming jobs.
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
